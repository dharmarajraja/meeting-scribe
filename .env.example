# Copy this file to .env and fill in your keys. Never commit the real .env file.

# Deepgram: https://console.deepgram.com/ (streaming speech-to-text with diarization)
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Mistral: https://console.mistral.ai/ (used to generate structured meeting minutes)
MISTRAL_API_KEY=your_mistral_api_key_here

# Optional: override the default model (mistral-large-latest)
# MISTRAL_MODEL=mistral-large-latest
